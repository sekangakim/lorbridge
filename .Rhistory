ipsatize_rows <- function(X) X - rowMeans(X, na.rm = TRUE)
svd_basis <- function(X, K, center_cols = FALSE) {
if (center_cols) X <- scale(X, center = TRUE, scale = FALSE)
s <- svd(X)
list(U = s$u[, 1:K, drop = FALSE],
D = diag(s$d[1:K]),
V = s$v[, 1:K, drop = FALSE])
}
principal_angles_deg <- function(A, B) {
Qa <- qr.Q(qr(A)); Qb <- qr.Q(qr(B))
s  <- svd(t(Qa) %*% Qb)$d
s[s > 1] <- 1
acos(s) * 180 / pi
}
procrustes_R <- function(A, B) {
S  <- t(B) %*% A
sv <- svd(S)
sv$u %*% t(sv$v)
}
maxpos_sign <- function(M) {
s <- sign(colSums(abs(M)) * sign(colMeans(M)))
s[s == 0] <- 1
sweep(M, 2, s, `*`)
}
variance_budget <- function(X) {
nn <- nrow(X); pp <- ncol(X)
LE <- matrix(rowMeans(X, na.rm = TRUE), nn, pp, byrow = FALSE)
PE <- X - LE
c(total_var = var(as.vector(X), na.rm = TRUE),
LE_var    = var(as.vector(LE), na.rm = TRUE),
PE_var    = var(as.vector(PE), na.rm = TRUE))
}
compare_ipsat_timing <- function(X, K, center_cols = FALSE) {
X     <- as.matrix(X)
Xstar <- ipsatize_rows(X)
# Ipsa-before: SVD on X*
sb       <- svd_basis(Xstar, K, center_cols)
B_before <- sb$V
# Ipsa-after: SVD on X, ipsatize scores, regress X* onto F*, orthonormalize
sa     <- svd_basis(X, K, center_cols)
F_raw  <- X %*% sa$V
F_star <- ipsatize_rows(F_raw)
BA     <- tryCatch(
solve(t(F_star) %*% F_star, t(F_star) %*% Xstar),
error = function(e) MASS::ginv(t(F_star) %*% F_star) %*% t(F_star) %*% Xstar
)
B_after <- qr.Q(qr(t(BA)))
ang               <- principal_angles_deg(B_before, B_after)
mean_cos_subspace <- mean(cos(ang * pi / 180))
R               <- procrustes_R(B_before, B_after)
B_after_aligned <- B_after %*% R
B_before_disp   <- maxpos_sign(B_before)
B_after_disp    <- maxpos_sign(B_after_aligned)
comp_cos <- sapply(seq_len(K), function(j)
sum(B_before_disp[, j] * B_after_disp[, j]) /
sqrt(sum(B_before_disp[, j]^2) * sum(B_after_disp[, j]^2)))
vb_raw  <- variance_budget(X)
vb_star <- variance_budget(Xstar)
cat(sprintf("\n== Ipsatization Timing Comparison (K = %d) ==\n", K))
cat("Principal angles (deg): ",
paste(round(ang, 4), collapse = ", "), "\n")
cat(sprintf("Mean cos(angle) = %.4f  (1.0 = perfect agreement)\n",
mean_cos_subspace))
cat("Component-wise cosine after Procrustes + sign fix: ",
paste(round(comp_cos, 4), collapse = ", "), "\n")
cat(sprintf("Variance budget (raw X):  total=%.4f, LE=%.4f, PE=%.4f\n",
vb_raw["total_var"], vb_raw["LE_var"], vb_raw["PE_var"]))
cat(sprintf("Variance budget (X*):     total=%.4f  (should equal PE above)\n",
vb_star["total_var"]))
invisible(list(B_before = B_before, B_after_aligned = B_after_aligned,
angles_deg = ang, mean_cos_subspace = mean_cos_subspace,
comp_cos = comp_cos))
}
ipsa_cmp <- compare_ipsat_timing(X, K = K)
## Ipsa-after via projector and orthonormalization (alternative form)
V_after         <- Hc %*% V[, 1:K, drop = FALSE]
V_after         <- qr.Q(qr(V_after))
S_ang           <- svd(crossprod(V_s[, 1:K, drop = FALSE], V_after))
angles_proj     <- acos(pmin(pmax(S_ang$d, -1), 1)) * 180 / pi
R_proc          <- S_ang$u %*% t(S_ang$v)
V_after_aligned <- V_after %*% R_proc
S_ang2          <- svd(crossprod(V_s[, 1:K, drop = FALSE], V_after_aligned))
angles_aligned  <- acos(pmin(pmax(S_ang2$d, -1), 1)) * 180 / pi
cat("\nPrincipal angles (Pc-projector form) BEFORE Procrustes:\n")
print(round(angles_proj, 6))
cat("Principal angles (Pc-projector form) AFTER  Procrustes:\n")
print(round(angles_aligned, 6))
## ----------------------------------------------------------------
## Tucker congruence coefficients (TCC = cos(theta_k))
## from the Pc-projector form:
##   Pc = I_J - (1/J)*1_J*1_J^T  (= Hc in this script; = P_c in MS)
## TCC >= 0.95 is the congruence criterion of
## Lorenzo-Seva & ten Berge (2006), equivalent to theta <= ~18 deg.
## In the real clinical data (n = 5,177): TCC > 0.999 for dims 1-3,
## confirming K^ccm = 3.  In the simulation (n = 300) the 3rd
## dimension may fall below 0.95 â€” a sampling artifact (see MS).
## ----------------------------------------------------------------
tucker_cc  <- cos(angles_proj * pi / 180)
tucker_tbl <- tibble::tibble(
Dimension           = seq_along(angles_proj),
Principal_Angle_deg = round(angles_proj, 6),
Tucker_CC           = round(tucker_cc,   6),
Pass_criterion      = tucker_cc >= 0.95
)
cat("\nTucker congruence coefficients (cos(theta_k)) â€” Pc-projector form:\n")
print(tucker_tbl)
K_ccm_sim <- sum(tucker_cc >= 0.95)
cat(sprintf("K^ccm in simulation (TCC >= 0.95): %d\n", K_ccm_sim))
cat(sprintf(
"Note: Real clinical data (n=5,177) yields K^ccm = 3 (all TCC > 0.999).\n"))
cat(sprintf(
"      Simulation (n=300) yields K^ccm = %d â€” sampling artifact expected at n=300.\n",
K_ccm_sim))
## ================================================================
## 2d. Aggregated PE profile g
## ================================================================
cat("\n--- 2d. Aggregated PE profile g ---\n")
aggregate_pe <- function(V, d, U, X_tilde = NULL, L = 4,
weights    = c("variance2","equal","variance","custom"),
alpha      = NULL,
enforce_zero_mean = TRUE,
sign_rule  = c("maxpos","none")) {
weights   <- match.arg(weights)
sign_rule <- match.arg(sign_rule)
V_use <- V[, 1:L, drop = FALSE]
dL    <- d[1:L]
U_use <- U[, 1:L, drop = FALSE]
if (enforce_zero_mean)
V_use <- sweep(V_use, 2, colMeans(V_use), "-")
if (sign_rule == "maxpos") {
for (k in 1:L) {
j_star <- which.max(abs(V_use[, k]))
if (V_use[j_star, k] < 0) {
V_use[, k] <- -V_use[, k]; U_use[, k] <- -U_use[, k]
}
}
}
alpha_vec <- switch(weights,
"equal"     = rep(1, L),
"variance"  = dL,
"variance2" = dL^2,
"custom"    = { if (is.null(alpha)) stop("Provide alpha"); alpha }
)
alpha_vec <- alpha_vec / sum(alpha_vec)
g_raw <- as.numeric(V_use %*% alpha_vec)
g_raw <- g_raw - mean(g_raw)
g     <- g_raw / sqrt(sum(g_raw^2))
g_norm <- sqrt(sum((as.numeric(V_use %*% alpha_vec))^2))
beta   <- alpha_vec / g_norm
w_k    <- dL * beta
match_proj <- as.numeric(U_use %*% w_k)
match_cos  <- NULL
if (!is.null(X_tilde)) {
numer     <- as.numeric(X_tilde %*% g)
denom     <- sqrt(rowSums(X_tilde^2))
match_cos <- numer / denom
}
list(g = g, alpha = alpha_vec, weights_per_component = w_k,
match_proj = match_proj, match_cos = match_cos)
}
## Evaluate stability: compare g at L=min(3,K) vs L=K
## When K=3, both calls use L=3 and cos(g_L3, g_LK) = 1.000
## (identical profiles), confirming no gain from a 4th dimension.
agg3 <- aggregate_pe(V = V_s, d = d_s, U = U_s, X_tilde = X_star,
L = min(3, K), weights = "variance2")
agg4 <- aggregate_pe(V = V_s, d = d_s, U = U_s, X_tilde = X_star,
L = K, weights = "variance2")
cos_g <- sum(agg3$g * agg4$g)
cat(sprintf("cos(g_Lmin3, g_LK) = %.6f\n", cos_g))
if (is.finite(cos_g) && cos_g >= 0.99) {
L <- 3; agg <- agg3
cat("Aggregation decision: L = 3 (4th adds negligible shape; cos >= 0.99)\n")
} else {
L <- K; agg <- agg4
cat(sprintf("Aggregation decision: L = %d\n", K))
}
g_loadings <- tibble::tibble(domain = subscales, g = round(agg$g, 6))
cat("\nAggregated PE profile loadings (g):\n"); print(g_loadings)
## Person scores
F_K      <- U_s[, 1:K, drop = FALSE] %*% diag(d_s[1:K])   # n x K
FAPA_agg <- agg$match_proj
FAPA_cos <- agg$match_cos
## ================================================================
## 2e. BCa CIs â€” subscale coordinates b_{j,k}  (V_s entries)
## ================================================================
cat("\n--- 2e. BCa CIs for subscale coordinates b_{j,k} ---\n")
set.seed(BOOT_SEED)
align_to_ref <- function(Vb, Vk) {
S   <- svd(crossprod(Vb, Vk))
R   <- S$u %*% t(S$v)
Val <- Vb %*% R
for (k in seq_len(ncol(Val)))
if (sum(Val[, k] * Vk[, k]) < 0) Val[, k] <- -Val[, k]
Val
}
stat_subscale_coords <- function(data, indices) {
Xs_b  <- X_star[indices, , drop = FALSE]
sv_b  <- svd(Xs_b)
Vb    <- sv_b$v[, 1:K, drop = FALSE]
Vb_al <- align_to_ref(Vb, V_s[, 1:K, drop = FALSE])
as.numeric(Vb_al)
}
boot_vs <- boot::boot(data = seq_len(n), statistic = stat_subscale_coords,
R = BOOT_R, sim = "ordinary", stype = "i", parallel = "no")
idx_map          <- expand.grid(domain = seq_len(p), comp = seq_len(K))
idx_map$subscale <- subscales[idx_map$domain]
est_mat          <- V_s[, 1:K, drop = FALSE]
bca_list <- vector("list", nrow(idx_map))
for (ii in seq_len(nrow(idx_map))) {
j  <- idx_map$domain[ii]; k <- idx_map$comp[ii]
id <- (k - 1) * p + j
ci <- tryCatch(boot::boot.ci(boot_vs, type = "bca", index = id),
error = function(e) NULL)
bca_list[[ii]] <- tibble::tibble(
Component = k, Domain = subscales[j], Estimate = est_mat[j, k],
BCa_Lo = if (!is.null(ci)) ci$bca[4] else NA_real_,
BCa_Hi = if (!is.null(ci)) ci$bca[5] else NA_real_
)
}
bca_subscales <- dplyr::bind_rows(bca_list) %>%
dplyr::mutate(dplyr::across(c(Estimate, BCa_Lo, BCa_Hi), ~round(., 6))) %>%
dplyr::arrange(Component, Domain)
cat("\n=== BCa CIs for subscale coordinates b_{j,k} (V_s) ===\n")
print(bca_subscales, n = nrow(bca_subscales))
## ================================================================
## 2f. BCa CIs â€” data-scale loadings  l_{j,k} = d_{s,k} * V_s[j,k]
## ================================================================
cat("\n--- 2f. BCa CIs for data-scale loadings l_{j,k} ---\n")
set.seed(BOOT_SEED)
stat_loadings_datascale <- function(data, indices) {
Xs_b  <- X_star[indices, , drop = FALSE]
sv_b  <- svd(Xs_b)
Vb    <- sv_b$v[, 1:K, drop = FALSE]
db    <- sv_b$d[1:K]
Vb_al <- align_to_ref(Vb, V_s[, 1:K, drop = FALSE])
Lb    <- sweep(Vb_al, 2, db, `*`)
as.numeric(Lb)
}
boot_ld <- boot::boot(data = seq_len(n), statistic = stat_loadings_datascale,
R = BOOT_R, sim = "ordinary", stype = "i", parallel = "no")
L_ref    <- sweep(V_s[, 1:K, drop = FALSE], 2, d_s[1:K], `*`)
bca_list_L <- vector("list", nrow(idx_map))
for (ii in seq_len(nrow(idx_map))) {
j  <- idx_map$domain[ii]; k <- idx_map$comp[ii]
id <- (k - 1) * p + j
ci <- tryCatch(boot::boot.ci(boot_ld, type = "bca", index = id),
error = function(e) NULL)
bca_list_L[[ii]] <- tibble::tibble(
Component = k, Domain = subscales[j], Estimate = L_ref[j, k],
BCa_Lo = if (!is.null(ci)) ci$bca[4] else NA_real_,
BCa_Hi = if (!is.null(ci)) ci$bca[5] else NA_real_
)
}
bca_loadings <- dplyr::bind_rows(bca_list_L) %>%
dplyr::mutate(dplyr::across(c(Estimate, BCa_Lo, BCa_Hi), ~round(., 6))) %>%
dplyr::arrange(Component, Domain)
cat("\n=== BCa CIs for DATA-SCALE loadings l_{j,k} ===\n")
print(bca_loadings, n = nrow(bca_loadings))
plane_tbl_L <- function(tbl, k1, k2) {
tbl %>%
dplyr::filter(Component %in% c(k1, k2)) %>%
tidyr::pivot_wider(id_cols = Domain,
names_from  = Component,
values_from = c(Estimate, BCa_Lo, BCa_Hi),
names_glue  = "Dim{Component}_{.value}") %>%
dplyr::arrange(Domain)
}
cat("\n-- Data-scale loadings: Plane (1-2) --\n")
print(plane_tbl_L(bca_loadings, 1, 2), n = p)
if (K >= 4) {
cat("\n-- Data-scale loadings: Plane (3-4) --\n")
print(plane_tbl_L(bca_loadings, 3, 4), n = p)
}
## ================================================================
## 2g. BMI detection, analysis frame, regression models
## ================================================================
cat("\n--- 2g. Regression models (ANCOVA) ---\n")
if (auto_detect_BMI) {
nm         <- names(df)
pick_name  <- function(cands)
unique(unlist(lapply(cands, function(rx)
grep(rx, nm, ignore.case = TRUE, value = TRUE))))[1]
col_BMIpre  <- pick_name(c(
"^bmi[_\\. -]*pre$","^pre[_\\. -]*bmi$","^bmi[_\\. -]*baseline$",
"^baseline[_\\. -]*bmi$","^bmi1$","^bmi[_\\. -]*t0$",
"^bmi[_\\. -]*visit1$","^bmi[_\\. -]*admit$","^admit[_\\. -]*bmi$"))
col_BMIpost <- pick_name(c(
"^bmi[_\\. -]*post$","^post[_\\. -]*bmi$","^bmi[_\\. -]*follow",
"^follow.*bmi$","^bmi2$","^bmi[_\\. -]*t1$",
"^bmi[_\\. -]*visit2$","^bmi[_\\. -]*discharge$","^discharge[_\\. -]*bmi$"))
message(sprintf("Auto-detected BMIpre:  %s",
ifelse(is.na(col_BMIpre),  "NOT FOUND", col_BMIpre)))
message(sprintf("Auto-detected BMIpost: %s",
ifelse(is.na(col_BMIpost), "NOT FOUND", col_BMIpost)))
}
have_pre  <- !is.na(col_BMIpre)  && col_BMIpre  %in% names(df)
have_post <- !is.na(col_BMIpost) && col_BMIpost %in% names(df)
if (!have_pre && !have_post)
stop("BMI columns not found. Set col_BMIpre/col_BMIpost manually.")
cov_present <- covariates[covariates %in% names(df)]
if (length(cov_present) < length(covariates))
warning(sprintf("Dropping missing covariates: %s",
paste(setdiff(covariates, cov_present), collapse = ", ")))
covariates <- cov_present
## -- Assemble analysis frame -------------------------------------
need_cols <- unique(c(if (have_post) col_BMIpost,
if (have_pre)  col_BMIpre,
covariates))
dat     <- df %>%
dplyr::mutate(FAPA_agg = FAPA_agg, FAPA_cos = FAPA_cos) %>%
dplyr::bind_cols(as.data.frame(F_K) |> setNames(paste0("FAPA_PC", 1:K)))
dat_anc <- dat %>%
dplyr::select(all_of(need_cols), starts_with("FAPA_PC"), FAPA_agg) %>%
na.omit()
## -- Data hygiene ------------------------------------------------
force_numeric <- function(x) {
if (is.numeric(x)) return(x)
suppressWarnings(as.numeric(trimws(gsub(",", "", as.character(x)))))
}
to_numeric_safe <- function(x) {
if (is.numeric(x)) return(x)
suppressWarnings(as.numeric(gsub("[^0-9\\.-]", "", as.character(x))))
}
for (nm in c(if (have_post) col_BMIpost, if (have_pre) col_BMIpre))
if (nm %in% names(dat_anc)) dat_anc[[nm]] <- force_numeric(dat_anc[[nm]])
for (nm in intersect(c("admage","durill"), covariates))
if (nm %in% names(dat_anc)) dat_anc[[nm]] <- force_numeric(dat_anc[[nm]])
fapa_cols <- grep("^FAPA_PC\\d+$", names(dat_anc), value = TRUE)
for (nm in c(fapa_cols, "FAPA_agg"))
if (nm %in% names(dat_anc)) dat_anc[[nm]] <- as.numeric(dat_anc[[nm]])
key_X    <- unique(c(fapa_cols, "FAPA_agg",
intersect(c("admage","durill"), covariates)))
keep_vars <- intersect(c(if (have_post) col_BMIpost,
if (have_pre)  col_BMIpre, key_X), names(dat_anc))
fin_ok <- function(df, vars) {
ok <- rep(TRUE, nrow(df))
for (v in vars)
ok <- ok & if (is.numeric(df[[v]])) is.finite(df[[v]]) else !is.na(df[[v]])
ok
}
dropped_n <- sum(!fin_ok(dat_anc, keep_vars))
if (dropped_n > 0)
message(sprintf("Data hygiene: dropped %d row(s) with non-finite values.", dropped_n))
dat_anc <- dat_anc[fin_ok(dat_anc, keep_vars), , drop = FALSE]
## -- Guardrails --------------------------------------------------
stopifnot(exists("col_BMIpre"), exists("col_BMIpost"))
dat_anc[[col_BMIpre]]  <- to_numeric_safe(dat_anc[[col_BMIpre]])
dat_anc[[col_BMIpost]] <- to_numeric_safe(dat_anc[[col_BMIpost]])
if ("admage" %in% names(dat_anc)) dat_anc$admage <- to_numeric_safe(dat_anc$admage)
if ("durill" %in% names(dat_anc)) dat_anc$durill <- to_numeric_safe(dat_anc$durill)
if ("edu"    %in% names(dat_anc)) dat_anc$edu    <- factor(dat_anc$edu)
if ("EDDX"   %in% names(dat_anc)) dat_anc$EDDX   <- factor(dat_anc$EDDX)
if (!"Delta_BMI" %in% names(dat_anc))
dat_anc$Delta_BMI <- dat_anc[[col_BMIpost]] - dat_anc[[col_BMIpre]]
## -- Model formulas ----------------------------------------------
pc_terms <- paste0("FAPA_PC", 1:K)
pc_terms <- pc_terms[pc_terms %in% names(dat_anc)]
rhs_pcs  <- if (length(pc_terms)) paste(pc_terms, collapse = " + ") else "1"
rhs_cov  <- if (length(covariates)) paste(covariates, collapse = " + ") else NULL
form_7a <- as.formula(paste(col_BMIpost, "~",
paste(c(rhs_pcs, col_BMIpre, rhs_cov), collapse = " + ")))
form_7b <- if ("FAPA_agg" %in% names(dat_anc)) {
as.formula(paste(col_BMIpost, "~",
paste(c("FAPA_agg", col_BMIpre, rhs_cov), collapse = " + ")))
} else {
NULL
}
form_delta <- as.formula(paste("Delta_BMI ~",
paste(c(rhs_pcs, rhs_cov), collapse = " + ")))
form_delta_pre <- as.formula(paste("Delta_BMI ~",
paste(c(col_BMIpre, rhs_pcs, rhs_cov), collapse = " + ")))
## -- Fit models --------------------------------------------------
fits <- list()
if (isTRUE(have_post) && isTRUE(have_pre)) {
fits$fit_7a            <- lm(form_7a,       data = dat_anc)
if (!is.null(form_7b))
fits$fit_7b          <- lm(form_7b,       data = dat_anc)
fits$fit_delta         <- lm(form_delta,    data = dat_anc)
fits$fit_delta_pre     <- lm(form_delta_pre, data = dat_anc)
} else if (isTRUE(have_post)) {
form_post <- as.formula(paste(col_BMIpost, "~",
paste(c(rhs_pcs, rhs_cov), collapse = " + ")))
fits$fit_post <- lm(form_post, data = dat_anc)
} else {
form_pre <- as.formula(paste(col_BMIpre, "~",
paste(c(rhs_pcs, rhs_cov), collapse = " + ")))
fits$fit_pre  <- lm(form_pre, data = dat_anc)
}
## -- Print summaries + FDR ---------------------------------------
print_fdr <- function(fit, label, pc_terms) {
tidy_fit <- broom::tidy(fit)
idx      <- which(tidy_fit$term %in% pc_terms)
tidy_fit$FDR_BH <- NA_real_
if (length(idx))
tidy_fit$FDR_BH[idx] <- p.adjust(tidy_fit$p.value[idx], method = "BH")
cat("\n===", label, "===\n")
print(dplyr::mutate(tidy_fit,
dplyr::across(c(estimate, std.error, statistic,
p.value, FDR_BH), ~round(., 6))))
invisible(tidy_fit)
}
if (!is.null(fits$fit_7a))
tidy_7a <- print_fdr(fits$fit_7a,
"ANCOVA 7a: BMIpost ~ K FAPA PCs + BMIpre + covariates", pc_terms)
if (!is.null(fits$fit_delta_pre)) {
tidy_dp <- print_fdr(fits$fit_delta_pre,
"Sensitivity 7a-delta: DeltaBMI ~ BMIpre + K FAPA PCs + covariates", pc_terms)
sig_pcs <- tidy_dp[which(tidy_dp$term %in% pc_terms), , drop = FALSE] %>%
dplyr::filter(!is.na(FDR_BH) & FDR_BH < 0.05) %>%
dplyr::select(term, estimate, p.value, FDR_BH)
if (nrow(sig_pcs)) { cat("\nFAPA PCs with FDR_BH < .05:\n"); print(sig_pcs) }
}
if (!is.null(fits$fit_7b)) {
tidy_7b <- broom::tidy(fits$fit_7b)
tidy_7b$FDR_BH <- NA_real_
idx_agg <- which(tidy_7b$term == "FAPA_agg")
if (length(idx_agg) == 1)
tidy_7b$FDR_BH[idx_agg] <- p.adjust(tidy_7b$p.value[idx_agg], method = "BH")
cat("\n=== ANCOVA 7b: BMIpost ~ Aggregated FAPA PE + BMIpre + covariates ===\n")
print(dplyr::mutate(tidy_7b,
dplyr::across(c(estimate, std.error, statistic,
p.value, FDR_BH), ~round(., 6))))
}
if (!is.null(fits$fit_delta))
print_fdr(fits$fit_delta,
"DeltaBMI ~ K FAPA PCs + covariates (no BMIpre)", pc_terms)
if (!is.null(fits$fit_post))
print_fdr(fits$fit_post,
"BMIpost ~ K FAPA PCs + covariates (no baseline)", pc_terms)
if (!is.null(fits$fit_pre))
print_fdr(fits$fit_pre,
"BMIpre ~ K FAPA PCs + covariates (cross-sectional)", pc_terms)
## ================================================================
## 2h. BCa bootstrap for regression coefficients
## ================================================================
cat("\n--- 2h. BCa bootstrap for regression coefficients ---\n")
set.seed(BOOT_SEED)
# (A) K-PC model (7a)
if (!is.null(fits$fit_7a)) {
f7a <- formula(fits$fit_7a)
boot_stat_K <- function(data, indices) {
ddd  <- data[indices, , drop = FALSE]
fit  <- try(lm(f7a, data = ddd), silent = TRUE)
if (inherits(fit, "try-error")) return(rep(NA_real_, K))
coefs <- coef(fit)
sapply(paste0("FAPA_PC", 1:K),
function(nm) if (nm %in% names(coefs)) coefs[[nm]] else NA_real_)
}
boot_K <- boot::boot(data = dat_anc, statistic = boot_stat_K,
R = BOOT_R, parallel = "no")
bca_tbl_K <- purrr::map_dfr(1:K, function(k) {
ci  <- tryCatch(boot::boot.ci(boot_K, type = "bca", index = k),
error = function(e) NULL)
est <- coef(fits$fit_7a)[paste0("FAPA_PC", k)]
tibble::tibble(term = paste0("FAPA_PC", k), estimate = est,
bca_lo = if (!is.null(ci)) ci$bca[4] else NA_real_,
bca_hi = if (!is.null(ci)) ci$bca[5] else NA_real_)
}) %>% dplyr::mutate(dplyr::across(c(estimate, bca_lo, bca_hi), ~round(., 6)))
cat("\n=== BCa CIs (ANCOVA 7a) for FAPA PCs ===\n"); print(bca_tbl_K)
}
# (B) Aggregated model (7b)
if (!is.null(fits$fit_7b)) {
f7b <- formula(fits$fit_7b)
boot_stat_agg <- function(data, indices) {
ddd <- data[indices, , drop = FALSE]
fit <- try(lm(f7b, data = ddd), silent = TRUE)
if (inherits(fit, "try-error")) return(NA_real_)
unname(coef(fit)["FAPA_agg"])
}
boot_AGG <- boot::boot(data = dat_anc, statistic = boot_stat_agg,
R = BOOT_R, parallel = "no")
ci_AGG   <- tryCatch(boot::boot.ci(boot_AGG, type = "bca"),
error = function(e) NULL)
bca_AGG  <- tibble::tibble(
term     = "FAPA_agg",
estimate = coef(fits$fit_7b)["FAPA_agg"],
bca_lo   = if (!is.null(ci_AGG)) ci_AGG$bca[4] else NA_real_,
bca_hi   = if (!is.null(ci_AGG)) ci_AGG$bca[5] else NA_real_
) %>% dplyr::mutate(dplyr::across(c(estimate, bca_lo, bca_hi), ~round(., 6)))
cat("\n=== BCa CIs (ANCOVA 7b) for Aggregated FAPA PE ===\n"); print(bca_AGG)
}
